:root {
  /* Surfaces */
  --bg-primary: #161B22;
  --bg-secondary: #161B22;
  --bg-card: #161B22;
  --bg-card-hover: #1C2128;
  --bg-page: #0D1117;
  --bg-gradient: #0D1117;

  /* Text */
  --text-primary: #E6EDF3;
  --text-secondary: #ADBAC7;
  --text-muted: #9198A1;
  --text-dim: #6E7681;
  --text-faint: #484F58;

  /* Borders */
  --border: #30363D;
  --border-hover: #444C56;

  /* Primary family is NEUTRAL now (the chrome is monochrome). Solids resolve to
     a mid neutral; the rgb channel is mid-gray so all the legacy
     rgba(var(--primary-rgb), a) washes render as subtle neutral overlays in both
     modes. The old purple aliases (--lavender/--violet) point here too. */
  --primary: #C8C8C8;
  --primary-rgb: 128, 128, 128;
  --primary-strong: #C8C8C8;
  --primary-strong-rgb: 128, 128, 128;
  --primary-deep: #C8C8C8;
  --primary-deep-rgb: 128, 128, 128;
  --primary-light: #ADBAC7;
  --primary-light-rgb: 128, 128, 128;
  --primary-indigo: #C8C8C8;
  --lavender: #ADBAC7;
  --violet: #ADBAC7;
  --violet-rgb: 128, 128, 128;

  /* Accent (GitHub green: #1F883D on light, #3FB950 on dark). Reserved for
     active states, focus, primary actions, progress, and salary. */
  --accent-lime: #E6EDF3;
  --accent-lime-rgb: 230, 237, 243;
  --accent-lime-strong: #E6EDF3;
  --accent-lime-soft: rgba(230, 237, 243, 0.12);
  --accent-lime-glow: rgba(230, 237, 243, 0.26);

  /* Focus ring: the ink accent so interaction reads as the brand everywhere */
  --focus-ring: #E6EDF3;
  --focus-ring-glow: rgba(230, 237, 243, 0.28);

  /* Status */
  --green: #2EA043;
  --green-glow: rgba(46, 160, 67, 0.12);
  --red: #DC4B43;
  --red-glow: rgba(220, 75, 67, 0.10);
  --amber: #D08A2E;
  --amber-glow: rgba(208, 138, 46, 0.10);
  --blue: #3E7BD6;
  --emerald: #16A06B;
  --emerald-glow: rgba(22, 160, 107, 0.15);
  --slate: #6B7280;
  --slate-light: #8A8A8A;

  /* ATS source — desaturated mid-tones, mode-independent (legible on both
     surfaces). Secondary workflow signal: recognizable, never loud. */
  --ats-greenhouse: #4F7D5E; --ats-greenhouse-rgb: 79, 125, 94;
  --ats-ashby: #6E66A6; --ats-ashby-rgb: 110, 102, 166;
  --ats-lever: #9C7E3A; --ats-lever-rgb: 156, 126, 58;
  --ats-workday: #5470A0; --ats-workday-rgb: 84, 112, 160;

  /* Score ramp — tinted chip for scores 7 and below (grays darker in light mode) */
  --score-good: #9C9C9C;
  --score-borderline: #8A8A8A;
  --score-weak: #A8A8A8;

  /* Score-chip ladder — solid filled chips for the top rungs, per-mode so they
     read on both surfaces. 10 (yellow) is the one deliberate pop of color. */
  --highlight: #F9EA4F;
  --highlight-ink: #000000;
  --score-10-bg: #F9EA4F; --score-10-ink: #000000;
  --score-9-bg: #ECECEC; --score-9-ink: #0D1117;
  --score-8-bg: #565656; --score-8-ink: #FFFFFF;

  /* Overlay tint channel + per-mode surfaces */
  --tint-rgb: 255, 255, 255;
  --ink-rgb: 236, 236, 236;
  --bar-bg: rgba(13, 17, 23, 0.92);
  --bar-sub-bg: rgba(13, 17, 23, 0.7);
  --overlay-bg: rgba(1, 4, 9, 0.8);
  --panel-bg: #161B22;
  --inverse: #0D1117;
  --shadow-rgb: 0, 0, 0;

  /* Glass + misc */
  --glass-bg: rgba(255, 255, 255, 0.03);
  --glass-border: rgba(255, 255, 255, 0.10);
  --glass-blur: blur(12px);
  --radius: 8px;
  --radius-sm: 6px;
  --radius-xs: 4px;
  --font-mono: 'SF Mono', 'Fira Code', 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;

  /* Practical UI scales. Mode-independent (like --radius), so they read from
     SHARED. Spacing is an 8pt scale with 2/4px sub-steps for the dense table;
     --page-gutter is the single shared horizontal page margin (header + list
     align to it). Overridden per-breakpoint in dashboard.css. */
  --space-2: 2px;
  --space-4: 4px;
  --space-xs: 8px;
  --space-s: 16px;
  --space-m: 24px;
  --space-l: 32px;
  --space-xl: 48px;
  --space-xxl: 80px;
  --page-gutter: 48px;
  --feed-measure: 1400px;

  --text-meta: 11px;
  --text-label: 12px;
  --text-body: 14px;
  --text-tiny: 16px;
  --text-small: 18px;
  --text-h4: 20px;
  --text-h3: 24px;
  --text-h2: 32px;
  --text-h1: 40px;

  --font-regular: 400;
  --font-medium: 500;
  --font-semibold: 600;
  --font-bold: 700;
  --lead-tight: 1.3;
  --lead-body: 1.6;

  /* Legacy aliases. --accent marks active/interactive states, so it points at
     the ink accent; the old purple aliases resolve to the neutral primary. */
  --accent: var(--accent-lime);
  --accent-glow: rgba(var(--accent-lime-rgb), 0.12);
  --purple: var(--primary);
  --standard-purple: var(--primary);
  --deep-purple: var(--primary-deep);
  --vibrant-purple: var(--primary-light);
  --muted-indigo: var(--primary-indigo);
  --lime-accent: var(--accent-lime);
  --violet-glow: rgba(var(--violet-rgb), 0.16);
}
@media (prefers-color-scheme: light) {
  :root:not([data-theme]) {
  /* Surfaces */
  --bg-primary: #FFFFFF;
  --bg-secondary: #F5F5F5;
  --bg-card: #FFFFFF;
  --bg-card-hover: #F5F5F5;
  --bg-page: #FFFFFF;
  --bg-gradient: #FFFFFF;

  /* Text */
  --text-primary: #000000;
  --text-secondary: #1A1A1A;
  --text-muted: #6B6B6B;
  --text-dim: #999999;
  --text-faint: #B8B8B8;

  /* Borders */
  --border: #ECECEC;
  --border-hover: #B8B8B8;

  /* Primary family is NEUTRAL now (the chrome is monochrome). Solids resolve to
     a mid neutral; the rgb channel is mid-gray so all the legacy
     rgba(var(--primary-rgb), a) washes render as subtle neutral overlays in both
     modes. The old purple aliases (--lavender/--violet) point here too. */
  --primary: #000000;
  --primary-rgb: 128, 128, 128;
  --primary-strong: #000000;
  --primary-strong-rgb: 128, 128, 128;
  --primary-deep: #000000;
  --primary-deep-rgb: 128, 128, 128;
  --primary-light: #1A1A1A;
  --primary-light-rgb: 128, 128, 128;
  --primary-indigo: #000000;
  --lavender: #1A1A1A;
  --violet: #1A1A1A;
  --violet-rgb: 128, 128, 128;

  /* Accent (GitHub green: #1F883D on light, #3FB950 on dark). Reserved for
     active states, focus, primary actions, progress, and salary. */
  --accent-lime: #000000;
  --accent-lime-rgb: 0, 0, 0;
  --accent-lime-strong: #000000;
  --accent-lime-soft: rgba(0, 0, 0, 0.12);
  --accent-lime-glow: rgba(0, 0, 0, 0.26);

  /* Focus ring: the ink accent so interaction reads as the brand everywhere */
  --focus-ring: #000000;
  --focus-ring-glow: rgba(0, 0, 0, 0.28);

  /* Status */
  --green: #2EA043;
  --green-glow: rgba(46, 160, 67, 0.12);
  --red: #DC4B43;
  --red-glow: rgba(220, 75, 67, 0.10);
  --amber: #D08A2E;
  --amber-glow: rgba(208, 138, 46, 0.10);
  --blue: #3E7BD6;
  --emerald: #16A06B;
  --emerald-glow: rgba(22, 160, 107, 0.15);
  --slate: #6B7280;
  --slate-light: #8A8A8A;

  /* ATS source — desaturated mid-tones, mode-independent (legible on both
     surfaces). Secondary workflow signal: recognizable, never loud. */
  --ats-greenhouse: #4F7D5E; --ats-greenhouse-rgb: 79, 125, 94;
  --ats-ashby: #6E66A6; --ats-ashby-rgb: 110, 102, 166;
  --ats-lever: #9C7E3A; --ats-lever-rgb: 156, 126, 58;
  --ats-workday: #5470A0; --ats-workday-rgb: 84, 112, 160;

  /* Score ramp — tinted chip for scores 7 and below (grays darker in light mode) */
  --score-good: #4A4A4A;
  --score-borderline: #6B6B6B;
  --score-weak: #8A8A8A;

  /* Score-chip ladder — solid filled chips for the top rungs, per-mode so they
     read on both surfaces. 10 (yellow) is the one deliberate pop of color. */
  --highlight: #F9EA4F;
  --highlight-ink: #000000;
  --score-10-bg: #F9EA4F; --score-10-ink: #000000;
  --score-9-bg: #111111; --score-9-ink: #FFFFFF;
  --score-8-bg: #565656; --score-8-ink: #FFFFFF;

  /* Overlay tint channel + per-mode surfaces */
  --tint-rgb: 0, 0, 0;
  --ink-rgb: 26, 26, 26;
  --bar-bg: rgba(255, 255, 255, 0.85);
  --bar-sub-bg: rgba(246, 248, 250, 0.75);
  --overlay-bg: rgba(20, 20, 20, 0.4);
  --panel-bg: #FFFFFF;
  --inverse: #FFFFFF;
  --shadow-rgb: 20, 20, 20;

  /* Glass + misc */
  --glass-bg: rgba(0, 0, 0, 0.02);
  --glass-border: rgba(0, 0, 0, 0.07);
  --glass-blur: blur(12px);
  --radius: 8px;
  --radius-sm: 6px;
  --radius-xs: 4px;
  --font-mono: 'SF Mono', 'Fira Code', 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;

  /* Practical UI scales. Mode-independent (like --radius), so they read from
     SHARED. Spacing is an 8pt scale with 2/4px sub-steps for the dense table;
