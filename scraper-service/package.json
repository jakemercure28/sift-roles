{
  "name": "scraper-service",
  "version": "1.0.0",
  "description": "TypeScript scraper worker: HTTP/JSON ATS scrapers behind a Fastify endpoint",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "queue-worker": "tsx src/queue-worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "update:golden": "UPDATE_GOLDEN=1 node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "bullmq": "^5.78.0",
    "fastify": "^5.2.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
