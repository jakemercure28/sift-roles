{
  "name": "job-search",
  "version": "1.0.0",
  "description": "Automated job search workflow",
  "type": "commonjs",
  "scripts": {
    "test": "npm run test:scraper-service",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run lint && npm run format:check && npm run test:scraper-service",
    "test:scraper-service": "npm --prefix scraper-service run typecheck && npm --prefix scraper-service test",
    "setup": "sh scripts/setup.sh"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
